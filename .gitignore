*.swo
*~

# OS junk
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
