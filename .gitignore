*.iobj
*.ipdb
*.exp
*.lib
*.app
*.application
*.manifest
*.deps.json
*.runtimeconfig.json
*.runtimeconfig.dev.json
project.lock.json
project.fragment.lock.json

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
.nuget/
nuget.config.user

# Test / coverage / analysis output
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml
coverage/
coverage*.json
coverage*.xml
*.lcov
BenchmarkDotNet.Artifacts/
TestResults/
*.VisualState.xml

# IDE / editor
.idea/
.vs/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.cursor/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.ncrunch*
*.[Rr]e[Ss]harper
_ReSharper*/
*.DotSettings
*.DotSettings.user
