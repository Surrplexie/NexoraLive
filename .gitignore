# =============================================================================
# NL (NexoraLive) — open-source allowlist
#
# Default: ignore everything. Only explicitly un-ignored paths are public.
# Public surface: source, tests, sample templates, scripts, BeamNG mod, and
# main documentation. Everything else (vision notes, secrets, build output,
# personal configs, IDE noise) stays local.
# =============================================================================

# ── Deny-all (allowlist mode) ────────────────────────────────────────────────
*
!*/

# ── Public root docs / license ───────────────────────────────────────────────
!.gitignore
!LICENSE
!README.md
!ROADMAP.md
!NLE_GUIDE.md

# ── Public trees ─────────────────────────────────────────────────────────────
!src/
!src/**
!tests/
!tests/**
!docs/
!docs/**
!samples/
!samples/**
!scripts/
!scripts/**
!beamng-mod/
!beamng-mod/**

# ── Re-ignore inside public trees ────────────────────────────────────────────

# Proprietary / personal notes (even if dropped under docs/)
nl.txt
*.txt
!LICENSE
notes/
private/
personal/
internal/
drafts/
scratch/
*_notes.*
*_draft.*
*_scratch.*
docs/DOGFOOD_NOTES.md
docs/DOGFOOD_BEAMNG.md
*.doc
*.docx
*.pdf
*.rtf
*.odt
*.xls
*.xlsx
*.ppt
*.pptx

# Secrets / credentials / local environment
.env
.env.*
!.env.example
*.env
secrets/
secrets.*
*secrets*
*credentials*
*credential*
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
*.jks
*.keystore
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.token
*.tokens
*.pat
*.apikey
*.api-key
auth.json
credentials.json
appsettings.local.json
appsettings.*.local.json
appsettings.Development.json
appsettings.Production.json
launchSettings.json
**/Properties/launchSettings.json

# OBS / streaming — real endpoints and passwords stay local
obs.local.json
**/obs.local.json
obs.production.json
**/obs.production.json

# Local hotkey / NLE configs (samples/ templates remain public)
hotkeys.local.nle
*.local.nle
**/hotkeys.local.nle
local/
**/local/

