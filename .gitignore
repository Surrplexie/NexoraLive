# Logs, runtime data, caches
*.log
*.log.*
/log/
/logs/
*.pid
*.seed
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
.cache/
.tmp/
temp/
tmp/

# Sample replay fixtures under samples/logs/ stay public
!samples/logs/
!samples/logs/**/*.log

# NL daemon runtime (mirrors %LOCALAPPDATA%\NL — do not commit)
hotkeys.log
**/hotkeys.log
NL/
**/NL/hotkeys.nle
**/NL/hotkeys.log

# Archives / media / fonts (not source; add exceptions if needed later)
*.zip
*.7z
