.chat/
.history/

# ── Keep sample fixtures that broad rules would otherwise hide ───────────────
!samples/**/*.nle
!samples/**/*.json
!samples/**/*.ndjson
!samples/**/*.log
!samples/**/hotkeys.json
!samples/**/obs.json
!scripts/**/*.ps1
!beamng-mod/**/*
