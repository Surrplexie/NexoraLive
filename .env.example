# NexoraLive — environment variables for public demo / Docker deployment (Phase E)
# Copy to .env and replace placeholder secrets before exposing the session server publicly.

# --- Public demo mode (required for internet-facing deploy) ---
# When enabled, NL_BUS_TOKEN and NL_OPERATOR_KEY become mandatory at startup.
NL_PUBLIC_MODE=false

# Fixed WebSocket bridge token (game bridges use ?token= on /nl/v1). Do not rotate casually in production.
NL_BUS_TOKEN=change-me-use-openssl-rand-hex-32

# Operator API key for session control + moderation writes (header: X-NL-Operator-Key or Authorization: Bearer).
NL_OPERATOR_KEY=change-me-use-openssl-rand-hex-32

# --- Network bind + ports ---
NL_BIND=127.0.0.1
NL_HTTP_PORT=27020
NL_WS_PORT=27021
NL_MOD_HTTP_PORT=27030

# --- Public URL overrides (manifest / bridge URLs behind reverse proxy + TLS) ---
# NL_PUBLIC_HOST=demo.example.com
# NL_PUBLIC_HTTP=https://demo.example.com
# NL_PUBLIC_WS=wss://demo.example.com/nl/v1
# NL_PUBLIC_MOD_HTTP=https://demo.example.com

# Comma-separated browser origins allowed for cross-origin API calls (public mode).
# Defaults to NL_PUBLIC_HTTP when NL_PUBLIC_MODE is on and this is unset.
# NL_CORS_ORIGINS=https://demo.example.com

# --- Data paths (Docker uses /data volume) ---
# NL_DATA_ROOT=/data
# NL_MODERATION_LOG=/data/moderation.jsonl
# NL_SP_STORE=/data/sp-profiles

# --- Phase F demo deploy (see docs/NL_DEPLOY.md) ---
# NL_DEMO_DOMAIN=demo.example.com
# CADDY_ACME_EMAIL=you@example.com
# NL_SESSION_IMAGE=ghcr.io/surrplexie/nexoralive/session-server:latest

# --- Phase G hosted demo loop (auto session + sidecar bridge in docker-compose.demo.yml) ---
# NL_DEMO_MODE=true
# NL_DEMO_CONFIG=demo.nle
# NL_DEMO_RESET_INTERVAL_MINUTES=60
# NL_DEMO_BRIDGE_INTERVAL=8

# --- Phase H spectator UX (public landing + try-a-rule triggers) ---
# NL_SPECTATOR_TRIGGERS=true
# NL_SPECTATOR_TRIGGER_RATE_PER_MIN=12
# NL_SPECTATOR_FEED_MAX=100
